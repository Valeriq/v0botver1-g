# ============================================
# AI Cold Email Bot - Environment Configuration
# ============================================
# Скопируйте этот файл в .env и заполните значениями
# Никогда не коммитьте .env файл в репозиторий

# ============================================
# Application Environment
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cold_email_bot

# ============================================
# Supabase Configuration
# ============================================
# Supabase Project URL (см. config/supabase/config.md)
SUPABASE_URL=https://your-project.supabase.co

# Supabase Service Role Key (см. config/supabase/config.md)
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Имя бакета для загрузки CSV файлов
SUPABASE_STORAGE_BUCKET=csv-uploads

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# Telegram Bot Configuration
# ============================================
# Получите токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram IDs администраторов (через запятую)
ADMIN_TELEGRAM_IDS=123456789,987654321

# ============================================
# AI Services Configuration
# ============================================
# OpenAI API Key для генерации email
OPENAI_API_KEY=your_openai_api_key_here

# Модель OpenAI (опционально, по умолчанию gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Perplexity API Key для поиска информации
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ============================================
# Google/Gmail Configuration
# ============================================
# Получите в Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Redirect URI для OAuth (обычно http://localhost:3001/api/auth/callback)
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/callback

# Google Cloud Pub/Sub Topic для Gmail push notifications
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-push

# ============================================
# Service URLs (для microservices)
# ============================================
CORE_API_URL=http://localhost:3000
GMAIL_SERVICE_URL=http://localhost:3001
AI_ORCHESTRATOR_URL=http://localhost:3002

# ============================================
# Optional: Monitoring & Observability
# ============================================
# Prometheus metrics endpoint (если включен)
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# Sentry DSN для error tracking (опционально)
SENTRY_DSN=

# ============================================
# Optional: Rate Limiting
# ============================================
# Rate limiting window в миллисекундах (15 минут по умолчанию)
RATE_LIMIT_WINDOW_MS=900000
# Максимальное количество запросов в окне
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Optional: CORS Configuration
# ============================================
# Разрешенные origins для CORS (через запятую)
CORS_ORIGINS=http://localhost:5000,http://localhost:3000

# ============================================
# Optional: File Upload Configuration
# ============================================
# Максимальный размер загружаемого файла в байтах (10MB по умолчанию)
MAX_FILE_SIZE=10485760

# Допустимые MIME типы для загрузки
ALLOWED_FILE_TYPES=text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# ============================================
# Optional: Email Sending Configuration
# ============================================
# Максимальное количество email для отправки в минуту (Gmail лимит)
EMAIL_RATE_LIMIT_PER_MINUTE=60

# Минимальный интервал между отправками в миллисекундах
EMAIL_SEND_INTERVAL_MS=1000
